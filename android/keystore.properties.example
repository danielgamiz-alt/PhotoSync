# Release signing for the PhotoSync APK.
#
# Copy this file to "keystore.properties" (same folder) and fill in your real
# values. The real keystore.properties and the .jks file are git-ignored — they
# are your app's signing identity, so keep them safe and NEVER commit them.
# If you lose this keystore you can no longer ship updates that install on top
# of older installs; back it up somewhere safe.
#
# Create the keystore once with (the JDK bundled with Android Studio has keytool):
#   keytool -genkeypair -v -keystore android/photosync-release.jks \
#           -alias photosync -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/ folder.

storeFile=photosync-release.jks
storePassword=CHANGE_ME
keyAlias=photosync
keyPassword=CHANGE_ME
