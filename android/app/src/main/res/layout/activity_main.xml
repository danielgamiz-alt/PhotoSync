<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:logo="@drawable/ic_launcher_foreground"
        app:logoScaleType="fitCenter"
        app:title="@string/app_name"
        app:titleTextAppearance="?attr/textAppearanceTitleLarge" />

    <!-- Summary bar: backup status on the left, a persistent "Set up backup"
         CTA on the right that stays visible until the server + name are set. -->
    <LinearLayout
        android:id="@+id/summaryBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="8dp">

        <!-- Backup status: a bold headline number with a thin progress bar that
             only appears while uploads are still pending. This is the app's main
             reassurance, so it reads as a title, not a caption. -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/summaryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <ProgressBar
                android:id="@+id/summaryProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="4dp"
                android:max="100"
                android:progressTint="@color/accent"
                android:visibility="gone" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/setupButton"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:minHeight="0dp"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="@string/setup_backup"
            android:visibility="gone" />
    </LinearLayout>

    <!-- First-run checklist card. Sits in the summary area (in place of
         instructions) whenever backup isn't set up; hidden once connected. -->
    <LinearLayout
        android:id="@+id/setupCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/setup_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/setupCardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_card_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/setupStep1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/setupStep2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <TextView
            android:id="@+id/setupStep3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="?attr/textAppearanceBodyMedium" />
    </LinearLayout>

    <!-- Update banner: shown when latest.json reports a newer app build than
         this one. Dismissible per version; "Update" opens the APK download. -->
    <LinearLayout
        android:id="@+id/updateBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/setup_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/update_banner_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/updateVersionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary" />

        <TextView
            android:id="@+id/updateNotesText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateDismissButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_dismiss" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateWhatsNewButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/update_whats_new" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/updateActionButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/update_action" />
        </LinearLayout>
    </LinearLayout>

    <!-- One-time invite nudge: appears once everything is backed up (the first
         "your photos are safe" moment), then never again after dismiss/share. -->
    <LinearLayout
        android:id="@+id/inviteCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/setup_card_bg"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invite_card_title"
            android:textAppearance="?attr/textAppearanceTitleMedium"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/invite_card_body"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inviteDismissButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/invite_card_dismiss" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/inviteShareButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/invite_card_share" />
        </LinearLayout>
    </LinearLayout>

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/photoGrid"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="1px"
                android:paddingBottom="76dp"
                android:scrollbars="none" />

            <!-- Single shared preview surface, moved over the active video
                 cell while scrolling. Sized/positioned in code. -->
            <androidx.media3.ui.PlayerView
                android:id="@+id/previewPlayer"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:visibility="gone" />

            <!-- Duration chip drawn over the preview (the cell's own chip is
                 hidden behind the player surface). Sized/positioned in code to
                 match the active cell; bottom-right like Google Photos. -->
            <FrameLayout
                android:id="@+id/previewChipContainer"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:clickable="false"
                android:focusable="false"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="4dp"
                    android:background="@drawable/video_chip_bg"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="5dp"
                    android:paddingVertical="2dp">

                    <ImageView
                        android:layout_width="11dp"
                        android:layout_height="11dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_video_mark" />

                    <TextView
                        android:id="@+id/previewDurationText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="3dp"
                        android:textColor="#FFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <!-- Floating date indicator that tracks the scroll position -->
            <TextView
                android:id="@+id/datePill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|center_horizontal"
                android:layout_marginTop="8dp"
                android:alpha="0"
                android:background="@drawable/date_pill_bg"
                android:paddingHorizontal="16dp"
                android:paddingVertical="6dp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/emptyText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="32dp"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                android:visibility="gone" />

            <!-- Selection bottom bar: two icon+label buttons, shown only in
                 selection mode. Replaces the filter pill visually. -->
            <LinearLayout
                android:id="@+id/selectionBottomBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/pill_track"
                android:elevation="8dp"
                android:orientation="horizontal"
                android:padding="4dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/selectionTrash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_delete" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/action_trash"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/selectionDeleteDevice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingHorizontal="28dp"
                    android:paddingVertical="10dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_phone_delete" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/action_delete_device"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bottom filter pill: Photos (all) vs Videos only. Segments are
                 styled in code (selected = accent fill). -->
            <LinearLayout
                android:id="@+id/filterPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="20dp"
                android:background="@drawable/pill_track"
                android:elevation="8dp"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/filterPhotos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="9dp"
                    android:text="@string/filter_photos"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/filterVideos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:paddingHorizontal="22dp"
                    android:paddingVertical="9dp"
                    android:text="@string/filter_videos_only"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
