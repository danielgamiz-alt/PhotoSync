<?xml version="1.0" encoding="utf-8"?>
<!-- One thumbnail in the viewer's bottom filmstrip. The selected cell shows a
     white border (filmstrip_selected_border) and full opacity; others are dimmed
     in code. Size/margins are fixed here so the strip scrolls smoothly. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/filmstripCell"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:layout_marginHorizontal="3dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="@drawable/filmstrip_selected_border">

    <ImageView
        android:id="@+id/filmstripThumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no"
        android:scaleType="centerCrop" />
</FrameLayout>
