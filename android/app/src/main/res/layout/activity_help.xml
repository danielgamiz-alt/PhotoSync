<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- About -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/help_title"
            android:textAppearance="?attr/textAppearanceTitleLarge" />

        <TextView
            android:id="@+id/helpVersionText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?android:attr/textColorSecondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/help_intro"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?android:attr/listDivider" />

        <!-- Support / donations — between About and the FAQ -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/support_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/support_body"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/supportButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/support_button" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="?android:attr/listDivider" />

        <!-- Common questions — each tap-to-expand (answers start collapsed). -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/help_faq_title"
            android:textAppearance="?attr/textAppearanceTitleMedium" />

        <TextView
            android:id="@+id/qWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_wifi"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aWifi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_wifi"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_server"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aServer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_server"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qInternet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_internet"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aInternet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_internet"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_background"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aBackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_background"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qLocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_locked"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aLocked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_locked"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qMissing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_missing"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aMissing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_missing"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_delete"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_delete"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qManual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_manual"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aManual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_manual"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

        <TextView
            android:id="@+id/qFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:paddingVertical="12dp"
            android:text="@string/help_q_free"
            android:textAppearance="?attr/textAppearanceTitleSmall" />

        <TextView
            android:id="@+id/aFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/help_a_free"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/text_secondary"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
