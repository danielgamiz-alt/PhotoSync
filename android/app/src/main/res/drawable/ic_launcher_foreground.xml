<?xml version="1.0" encoding="utf-8"?>
<!--
  "Aperture" launcher icon: a six-blade lens iris in spectrum colors around a
  hexagonal aperture hole. The hole is left unpainted so the dark adaptive
  background shows through (the "dark field" that makes the colors pop).
  Center (54,54), outer radius 32, inner hexagon radius 12; blades are 60°
  sectors, dividers at 30/90/150/210/270/330° clockwise from top.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Red (top) -->
    <path
        android:fillColor="#F2473F"
        android:pathData="M48,43.608 L38,26.288 A32,32 0 0 1 70,26.288 L60,43.608 Z" />
    <!-- Orange (top-right) -->
    <path
        android:fillColor="#F7972E"
        android:pathData="M60,43.608 L70,26.288 A32,32 0 0 1 86,54 L66,54 Z" />
    <!-- Yellow (bottom-right) -->
    <path
        android:fillColor="#F6C72E"
        android:pathData="M66,54 L86,54 A32,32 0 0 1 70,81.712 L60,64.392 Z" />
    <!-- Green (bottom) -->
    <path
        android:fillColor="#2EC36A"
        android:pathData="M60,64.392 L70,81.712 A32,32 0 0 1 38,81.712 L48,64.392 Z" />
    <!-- Cyan (bottom-left) -->
    <path
        android:fillColor="#25C4DE"
        android:pathData="M48,64.392 L38,81.712 A32,32 0 0 1 22,54 L42,54 Z" />
    <!-- Purple (top-left) -->
    <path
        android:fillColor="#7C5CF0"
        android:pathData="M42,54 L22,54 A32,32 0 0 1 38,26.288 L48,43.608 Z" />

    <!-- Dark separators between blades (the iris "leaves") -->
    <path
        android:strokeColor="#0F1012"
        android:strokeWidth="1.6"
        android:pathData="M60,43.608 L70,26.288 M66,54 L86,54 M60,64.392 L70,81.712 M48,64.392 L38,81.712 M42,54 L22,54 M48,43.608 L38,26.288" />
</vector>
